# 請勿把真正的 API Key 上傳到 GitHub。
# 部署到 Streamlit Community Cloud 時，將以下內容貼到 App Settings → Secrets。

GEMINI_API_KEY = "貼上你的_Gemini_API_Key"
# OPENAI_API_KEY = "貼上你的_OpenAI_API_Key"

# 留空或刪除即可讓任何人直接使用。
# APP_PASSWORD = "班級共用密碼"

# 每個瀏覽器工作階段最多可呼叫 AI 幾次。
MAX_ANALYSES_PER_SESSION = 5

# 伺服器沒有內建 Key 時，是否允許使用者輸入自己的 Key。
ALLOW_USER_API_KEY = true
